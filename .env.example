# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------------
# 🚀 UPCOMING INTEGRATIONS (E-commerce / Backend)
# The application currently runs entirely with static data. 
# You will need to fill these in when you start integrating an actual backend.
# ---------------------------------------------------------------------------------

# Payments (Stripe)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Database (Prisma / Drizzle / PostgreSQL)
# DATABASE_URL="postgresql://user:password@localhost:5432/kitscompany"

# Email / Newsletter (Resend / SendGrid)
# RESEND_API_KEY=re_...

# Authentication
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Shopify Storefront API
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN="your-storefront-access-token"
